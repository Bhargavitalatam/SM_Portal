# Application
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed CORS origins. Use * to allow all origins (not recommended in production).
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgres://gmpuser:gmppassword@localhost:5432/gmpdb
DB_HOST=localhost
DB_PORT=5432
DB_USER=gmpuser
DB_PASSWORD=gmppassword
DB_NAME=gmpdb
# Set to 'true' only when connecting to a PostgreSQL instance that requires SSL (e.g. cloud-hosted)
DB_SSL=false

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=1h

# OAuth 2.0 (GitHub)
OAUTH_CLIENT_ID=your_github_oauth_client_id
OAUTH_CLIENT_SECRET=your_github_oauth_client_secret
OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Default Admin User (created on first seed)
ADMIN_EMAIL=admin@grantportal.com
ADMIN_PASSWORD=Admin@123456

# Seeding
SEED_ON_START=true
